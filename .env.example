# ============================================================================
# Ticker - environment variables (names + placeholders only)
# Copy to .env.local (gitignored) and fill with real values for local dev.
# Production values live in the Vercel dashboard. NEVER commit a real secret.
# ============================================================================

# --- App ---
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- Supabase (Phase 4: database & auth) ---
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"   # server-only; never exposed to the client

# --- Stripe (Phase 7: payments & paywall) ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxx"
STRIPE_SECRET_KEY="sk_test_xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"
STRIPE_PRICE_READER="price_xxx"                     # Reader $20/mo price id
STRIPE_PRICE_PRO="price_xxx"                        # Pro $40/mo price id

# --- Resend (Phase 8: email) ---
RESEND_API_KEY="re_xxx"
EMAIL_FROM="Ticker <hello@ticker.example>"

# --- Model API / tweet engine (Phase 5) ---
MODEL_PROVIDER="nim"                                # dev: nim | prod: fireworks | together | openrouter
MODEL_BASE_URL="https://integrate.api.nvidia.com/v1"
MODEL_API_KEY="your-model-api-key"
ENGINE_ENABLED="false"                              # kill switch; never publish without explicit approval
CRON_SECRET="generate-a-long-random-string"         # protects the engine cron route

# --- Analytics & monitoring (Phase 9) ---
NEXT_PUBLIC_PLAUSIBLE_DOMAIN="ticker.example"
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
