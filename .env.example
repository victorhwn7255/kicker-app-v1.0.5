# ============================================================================
# Ticker - environment variables (names + placeholders only)
# Copy to .env.local (gitignored) and fill with real values for local dev.
# Production values live in the Vercel dashboard. NEVER commit a real secret.
# ============================================================================

# --- App ---
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- Supabase (Phase 4: database & auth) ---
# Uses the NEW Supabase API key system (publishable/secret), not legacy anon/service_role.
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxx"   # safe in the browser; RLS protects the data
SUPABASE_SECRET_KEY="sb_secret_xxx"                         # server-only; never exposed to the client
# Direct Postgres connection - used ONLY by `pnpm db:migrate` (DDL can't go via the API).
# Dashboard: Project Settings -> Database -> Connection string -> URI (include the db password).
SUPABASE_DB_URL="postgresql://postgres.your-ref:your-db-password@your-host.pooler.supabase.com:5432/postgres"

# --- Stripe (Phase 7: payments & paywall) ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxx"
STRIPE_SECRET_KEY="sk_test_xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"
STRIPE_PRICE_READER="price_xxx"                     # Reader $20/mo price id
STRIPE_PRICE_PRO="price_xxx"                        # Pro $40/mo price id

# --- Resend (Phase 8: email) ---
RESEND_API_KEY="re_xxx"
EMAIL_FROM="Ticker <hello@ticker.example>"

# --- Model API / tweet engine (Phase 5) ---
# Production chain: primary Groq (Llama 3.3 70B) -> fallback Gemini Flash; paid escape hatch: OpenRouter.
MODEL_PROVIDER="groq"                               # groq | gemini | nim | openrouter
GROQ_API_KEY="gsk_xxx"                              # AI SDK default var name (@ai-sdk/groq)
GOOGLE_GENERATIVE_AI_API_KEY="AIza_xxx"             # AI SDK default var name (@ai-sdk/google)
MODEL_BASE_URL="https://integrate.api.nvidia.com/v1"   # NIM base - dev A/B only, never production
MODEL_API_KEY="nvapi-xxx"                           # NIM trial key (optional)
ENGINE_ENABLED="false"                              # kill switch; never publish without explicit approval
CRON_SECRET="generate-a-long-random-string"         # protects the engine cron route

# --- Analytics & monitoring (Phase 9) ---
NEXT_PUBLIC_PLAUSIBLE_DOMAIN="ticker.example"
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
